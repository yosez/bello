Grammar

    0 $accept: statement $end

    1 statement: IMPORT STR_LTR

    2 @1: /* empty */

    3 statement: statement close_execute_last_statement @1 single_statement LF check_indent build_statement_stack execute_single_statement
    4          | statement INDENT single_statement LF check_indent build_statement_stack
    5          | statement LF close_execute_statement
    6          | statement END_FILE close_execute_last_statement
    7          | error
    8          | /* empty */
    9          | END_FILE

   10 check_indent: /* empty */

   11 build_statement_stack: /* empty */

   12 close_execute_statement: /* empty */

   13 close_execute_last_statement: /* empty */

   14 execute_single_statement: /* empty */

   15 single_statement: expression_statement
   16                 | if_statement
   17                 | else_statement
   18                 | elseif_statement
   19                 | for_statement
   20                 | while_statement
   21                 | break_statement
   22                 | continue_statement
   23                 | return_statement
   24                 | function_statement
   25                 | nop_statement
   26                 | var_statement
   27                 | global_statement
   28                 | class_statement
   29                 | error

   30 single_statement_no_semicolon: expression_statement
   31                              | if_statement
   32                              | for_statement
   33                              | while_statement
   34                              | do_while_statement
   35                              | null_statement

   36 null_statement: /* empty */

   37 nop_statement: NOP

   38 statement_block: LEFT_BRACE block_list RIGHT_BRACE
   39                | LEFT_BRACE RIGHT_BRACE

   40 block_list: single_statement
   41           | block_list single_statement

   42 expression_statement: expression

   43 expression: value_expression
   44           | lvalue_operation_expression
   45           | unary_expression
   46           | binary_expression
   47           | array_expression
   48           | new_array_expression
   49           | shortcut_expression

   50 lvalue_operation_expression: assign_expression
   51                            | self_operation_expression

   52 assign_expression: lvalue_expression ASSIGN expression
   53                  | lvalue_expression ADD_ASSIGN expression
   54                  | lvalue_expression SUB_ASSIGN expression
   55                  | lvalue_expression MUL_ASSIGN expression
   56                  | lvalue_expression DIV_ASSIGN expression
   57                  | lvalue_expression MOD_ASSIGN expression

   58 self_operation_expression: INCREMENT lvalue_expression
   59                          | DECREMENT lvalue_expression
   60                          | lvalue_expression INCREMENT
   61                          | lvalue_expression DECREMENT

   62 unary_expression: SUB expression
   63                 | ADD expression
   64                 | LEFT_PAREN expression RIGHT_PAREN
   65                 | NOT expression
   66                 | BIT_NOT expression

   67 binary_expression: expression ADD expression
   68                  | expression SUB expression
   69                  | expression MUL expression
   70                  | expression DIV expression
   71                  | expression MOD expression
   72                  | expression AND expression
   73                  | expression OR expression
   74                  | expression XOR expression
   75                  | expression EQ expression
   76                  | expression NE expression
   77                  | expression GT expression
   78                  | expression GE expression
   79                  | expression LT expression
   80                  | expression LE expression
   81                  | expression BIT_AND expression
   82                  | expression BIT_OR expression
   83                  | expression BIT_XOR expression
   84                  | expression QM expression COLON expression

   85 shortcut_expression: SHORTCUT_PRINTLN element_list

   86 value_expression: INT_LTR
   87                 | FLT_LTR
   88                 | BLN_LTR
   89                 | STR_LTR
   90                 | NLL_LTR
   91                 | function_expression
   92                 | lvalue_expression
   93                 | NEW IDENTIFER

   94 lvalue_expression: IDENTIFER
   95                  | lvalue_expression DOT IDENTIFER
   96                  | lvalue_expression evaluate_list
   97                  | lvalue_expression DOT function_expression

   98 array_expression: LEFT_QUAD element_list RIGHT_QUAD
   99                 | LEFT_QUAD RIGHT_QUAD

  100 new_array_expression: NEW_ARRAY LEFT_PAREN expression RIGHT_PAREN

  101 element_list: expression
  102             | element_list COMMA expression

  103 var_statement: VAR assign_list
  104              | SHARED VAR assign_list

  105 global_statement: GLOBAL assign_list

  106 assign_list: IDENTIFER
  107            | IDENTIFER ASSIGN expression
  108            | assign_list COMMA IDENTIFER
  109            | assign_list COMMA IDENTIFER ASSIGN expression

  110 function_expression: IDENTIFER LEFT_PAREN argument_list RIGHT_PAREN
  111                    | IDENTIFER LEFT_PAREN RIGHT_PAREN

  112 argument_list: expression
  113              | IDENTIFER COLON expression
  114              | argument_list COMMA expression
  115              | argument_list COMMA IDENTIFER COLON expression

  116 parameter_list: IDENTIFER
  117               | IDENTIFER ASSIGN expression
  118               | parameter_list COMMA IDENTIFER
  119               | parameter_list COMMA IDENTIFER ASSIGN expression

  120 evaluate_list: LEFT_QUAD expression RIGHT_QUAD
  121              | LEFT_QUAD expression COLON expression RIGHT_QUAD
  122              | LEFT_QUAD expression COLON expression COLON RIGHT_QUAD
  123              | LEFT_QUAD expression COLON expression COLON expression RIGHT_QUAD
  124              | LEFT_QUAD expression COLON RIGHT_QUAD
  125              | LEFT_QUAD expression COLON COLON RIGHT_QUAD
  126              | LEFT_QUAD expression COLON COLON expression RIGHT_QUAD
  127              | LEFT_QUAD COLON expression RIGHT_QUAD
  128              | LEFT_QUAD COLON expression COLON RIGHT_QUAD
  129              | LEFT_QUAD COLON expression COLON expression RIGHT_QUAD
  130              | LEFT_QUAD COLON COLON RIGHT_QUAD
  131              | evaluate_list LEFT_QUAD expression RIGHT_QUAD
  132              | evaluate_list LEFT_QUAD expression COLON expression RIGHT_QUAD
  133              | evaluate_list LEFT_QUAD expression COLON expression COLON RIGHT_QUAD
  134              | evaluate_list LEFT_QUAD expression COLON expression COLON expression RIGHT_QUAD
  135              | evaluate_list LEFT_QUAD expression COLON RIGHT_QUAD
  136              | evaluate_list LEFT_QUAD expression COLON COLON RIGHT_QUAD
  137              | evaluate_list LEFT_QUAD expression COLON COLON expression RIGHT_QUAD
  138              | evaluate_list LEFT_QUAD COLON expression RIGHT_QUAD
  139              | evaluate_list LEFT_QUAD COLON expression COLON RIGHT_QUAD
  140              | evaluate_list LEFT_QUAD COLON expression COLON expression RIGHT_QUAD
  141              | evaluate_list LEFT_QUAD COLON COLON RIGHT_QUAD

  142 if_statement: IF expression

  143 else_statement: ELSE

  144 elseif_statement: ELSEIF expression

  145 for_statement: FOR single_statement_no_semicolon SEMICOLON expression_statement SEMICOLON single_statement_no_semicolon
  146              | FOR single_statement_no_semicolon COLON expression_statement COLON single_statement_no_semicolon

  147 while_statement: WHILE expression
  148                | WHILE

  149 do_while_statement: DO structure_statement WHILE LEFT_PAREN expression_statement RIGHT_PAREN SEMICOLON

  150 break_statement: BREAK
  151                | BREAK LEFT_PAREN expression RIGHT_PAREN

  152 continue_statement: CONTINUE
  153                   | CONTINUE LEFT_PAREN expression RIGHT_PAREN

  154 structure_statement: single_statement
  155                    | statement_block

  156 function_statement: FUNC IDENTIFER LEFT_PAREN parameter_list RIGHT_PAREN
  157                   | FUNC IDENTIFER LEFT_PAREN RIGHT_PAREN
  158                   | SHARED FUNC IDENTIFER LEFT_PAREN parameter_list RIGHT_PAREN
  159                   | SHARED FUNC IDENTIFER LEFT_PAREN RIGHT_PAREN

  160 class_statement: CLASS IDENTIFER

  161 return_statement: RETURN
  162                 | RETURN expression


